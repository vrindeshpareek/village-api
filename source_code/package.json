{
  "name": "village-api",
  "version": "1.0.0",
  "private": true,
  "description": "Production-ready SaaS platform for India village-level geography APIs.",
  "workspaces": [
    "api",
    "frontend",
    "demo-client"
  ],
  "scripts": {
    "dev": "npm run dev --workspace api",
    "dev:api": "npm run dev --workspace api",
    "dev:dashboard": "npm run dev --workspace frontend",
    "dev:demo": "npm run dev --workspace demo-client",
    "build": "npm run build --workspace api && npm run build --workspace frontend && npm run build --workspace demo-client",
    "lint": "npm run lint --workspace frontend && npm run lint --workspace demo-client",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema prisma/schema.prisma",
    "prisma:push": "prisma db push --schema prisma/schema.prisma",
    "prisma:deploy": "prisma migrate deploy --schema prisma/schema.prisma",
    "prisma:seed": "node prisma/seed.js",
    "etl:setup": "python -m pip install xlrd==2.0.1 openpyxl==3.1.5 odfpy==1.4.1 python-dotenv==1.0.1",
    "etl:dry-run": "python etl/import_mdds.py etl/input/all-india-villages-master-list-excel/dataset --dry-run",
    "etl:import": "python etl/import_mdds.py etl/input/all-india-villages-master-list-excel/dataset",
    "deploy:preview": "vercel",
    "deploy:prod": "vercel --prod"
  },
  "devDependencies": {
    "prisma": "^5.22.0"
  }
}
